rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && request.resource.data.keys().hasOnly(['profile', 'pantry', 'onboarded', 'schedule']);
    }

    // Rate limits — only readable by owner, writable only by admin SDK (Cloud Functions)
    match /rate_limits/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }
  }
}
